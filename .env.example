# ─────────────────────────────────────────────────────────────────────────────
# Payment — VietQR / Ngân hàng / MoMo
# ─────────────────────────────────────────────────────────────────────────────
# Mã BIN ngân hàng (8 chữ số). Tra cứu: https://vietqr.net/
# Vietcombank → 970436 | BIDV → 970448 | VietinBank → 970415 | Agribank → 970405 | MB Bank → 970422
VITE_PAYMENT_BANK_BIN=970422

# Số tài khoản nhận tiền (không dấu cách)
VITE_PAYMENT_ACCOUNT_NO=0775316675

# Tên chủ tài khoản (không dấu)
VITE_PAYMENT_ACCOUNT_NAME=VU DANG THANH

# Tên ngân hàng hiển thị (không dấu, viết đúng chính tả)
VITE_PAYMENT_BANK_NAME=MB Bank

# Số điện thoại MoMo nhận tiền (bỏ trống nếu chỉ dùng ngân hàng)
VITE_PAYMENT_MOMO_PHONE=  

# Prefix trong nội dung CK (không dấu, viết liền). VD: "BASEW 0901234567"
VITE_PAYMENT_COMPANY_PREFIX=BASEW

# ─────────────────────────────────────────────────────────────────────────────
# GPS Tracker
# ─────────────────────────────────────────────────────────────────────────────
VITE_TRACKER_API_BASE=https://gps-tracker.ahcntab.workers.dev

# ─────────────────────────────────────────────────────────────────────────────
# Lead collection
# ─────────────────────────────────────────────────────────────────────────────
# Preferred: Google Apps Script webhook writes leads to Google Sheet.
VITE_GOOGLE_SHEET_WEBHOOK_URL= https://script.google.com/macros/s/AKfycbxJQAbxKFrGSvxYXryyx3mu3Cdj3ZRTVmYFr6Y9V59ZnUfM0oESExIqso-hKv9NCT0EDQ/exec

# Fallback: Vite dev/preview saves to data/leads.jsonl.
VITE_LOCAL_LEAD_ENDPOINT=/api/leads

# ─────────────────────────────────────────────────────────────────────────────
# Demo / UI
# ─────────────────────────────────────────────────────────────────────────────
# Embed URL, or put a local file in public/videos and use:
# VITE_DEMO_VIDEO_EMBED_URL=videos/basew-demo.mp4
VITE_DEMO_VIDEO_EMBED_URL=https://www.youtube.com/embed/gMdlG_eQSuA

# Landing opens this URL when users click the web tracking demo button.
# Local default assumes web-tracking is running on port 3000.
VITE_TRACKING_WEB_URL=https://thanhvu220809.github.io/Tracking_page/
VITE_LEAD_FORM_DEMO_MODE=false

# ─────────────────────────────────────────────────────────────────────────────
# Analytics
# ─────────────────────────────────────────────────────────────────────────────
VITE_ENABLE_ANALYTICS=false
VITE_GA_MEASUREMENT_ID=
VITE_META_PIXEL_ID=
